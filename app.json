{
  "expo": {
    "name": "Khadam",
    "slug": "khadam-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "khadam",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "net.khdm.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Khadam needs photo library access so you can upload profile and office documents.",
        "NSCameraUsageDescription": "Khadam needs camera access so you can capture profile and office documents.",
        "NSPhotoLibraryAddUsageDescription": "Khadam may save selected images when preparing uploads."
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "net.khdm.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.CAMERA"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-image",
      [
        "expo-image-picker",
        {
          "photosPermission": "Khadam needs photo library access so you can upload profile and office documents.",
          "cameraPermission": "Khadam needs camera access so you can capture profile and office documents."
        }
      ],
      "expo-document-picker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
